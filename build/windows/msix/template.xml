<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="nurvis"
        Arguments=""
        InstallLocation="C:\Program Files\Nurvis\Nurvis">
    </Installer>
    <PackageInformation
        PackageName="Nurvis"
        PackageDisplayName="Nurvis"
        PublisherName="CN=Nurvis"
        PublisherDisplayName="Nurvis"
        Version="0.1.0.0"
        PackageDescription="Nurvis desktop application">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="dev.nurvis.lite"
                Description="Nurvis desktop application"
                DisplayName="Nurvis"
                ExecutableName="nurvis"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Nurvis</DisplayName>
            <PublisherDisplayName>Nurvis</PublisherDisplayName>
            <Description>Nurvis desktop application</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="nurvis.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
